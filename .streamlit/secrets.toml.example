# Streamlit Community Cloud → Settings → Secrets bölümüne BU içeriği yapıştır
# (gerçek anahtarlarla). Yerelde bunun yerine .env kullanılır.
#
# secrets.toml ASLA git'e commit edilmez (.gitignore korur).

VOYAGE_AI_KEY = "pa-..."
PINECONE_API_KEY = "pcsk_..."

# LLM sağlayıcı: "groq" (varsayılan) veya "openrouter"
LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_..."

# OpenRouter kullanacaksan (LLM_PROVIDER="openrouter"):
# OPENROUTER_API_KEY = "sk-or-..."
# OPENROUTER_MODEL = "openai/gpt-oss-120b:free"
