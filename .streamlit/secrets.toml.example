# Streamlit Community Cloud → Settings → Secrets bölümüne BU içeriği yapıştır
# (gerçek anahtarlarla). Yerelde bunun yerine .env kullanılır.
#
# secrets.toml ASLA git'e commit edilmez (.gitignore korur).

VOYAGE_AI_KEY = "pa-..."
PINECONE_API_KEY = "pcsk_..."

# LLM sağlayıcı seçenekleri:
#   "groq"       → sadece Groq
#   "openrouter" → sadece OpenRouter
#   "auto"       → önce Groq, kota dolarsa/hata olursa otomatik OpenRouter'a düşer (ÖNERİLEN)
LLM_PROVIDER = "auto"

# auto/groq için:
GROQ_API_KEY = "gsk_..."

# auto/openrouter için (auto'da yedek olarak kullanılır):
OPENROUTER_API_KEY = "sk-or-..."
OPENROUTER_MODEL = "openai/gpt-oss-120b:free"
